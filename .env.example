# ─────────────────────────────────────────────────────────
# Stock Control — Unified Environment Configuration
# Copy this file to .env and set the correct values.
# ─────────────────────────────────────────────────────────

# --- BACKEND SETTINGS ---
# development | production | staging
ENVIRONMENT=local
SECRET_KEY=your-super-secret-key-at-least-32-chars-long
DATABASE_URL=sqlite:///./stock_local.db
REDIS_URL=redis://localhost:6379/0

# CORS settings (comma separated list)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- FRONTEND SETTINGS ---
# This is usually passed to Vite during build time as VITE_API_BASE_URL
# For local dev: http://127.0.0.1:8000/api/v1
# For production: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
